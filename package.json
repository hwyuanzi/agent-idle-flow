{
  "name": "agent-idle-flow",
  "version": "1.0.0",
  "description": "Intercept idle LLM wait time with micro-tasks",
  "main": "dist/cli.js",
  "bin": {
    "aiflow": "./dist/cli.js"
  },
  "scripts": {
